    "@hono/node-server": "^1.8.0",
    "@libsql/client": "^0.17.2",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "hono": "^4.2.0",
    "socket.io": "^4.7.0",
    "tsx": "^4.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
